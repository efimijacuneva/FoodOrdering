# ── .env.example ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and must NEVER be committed.
#
# Development quick-start (Docker Compose):
#   cp .env.example .env
#   # Edit .env — at minimum set POSTGRES_PASSWORD and SECRET_KEY
#   docker compose up          # loads docker-compose.override.yml automatically
#
# Production:
#   cp .env.example .env
#   # Set ALL values below to strong, random production values
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d

# ── Django ────────────────────────────────────────────────────────────────────
# Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to True ONLY during local development (never in production)
DEBUG=False

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of trusted origins for CSRF (must include scheme)
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=food_ordering_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production

# ── Email ─────────────────────────────────────────────────────────────────────
DEFAULT_FROM_EMAIL=Tasty Bites <noreply@tastybites.mk>

# ── Docker / CI (optional) ────────────────────────────────────────────────────
# DOCKERHUB_USERNAME=your-dockerhub-username
# IMAGE_TAG=latest
# HTTP_PORT=80
